# ============================================================
# Ask My PDF Bot - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM Provider (choose one) ---
# Option 1: Google Gemini API (RECOMMENDED - free tier available)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAXh2KHoCIDrrwceD5K8MXUzAbz1dJBpUg

# Option 2: If using Ollama locally (no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=tinyllama

# --- LLM Configuration ---
LLM_PROVIDER=gemini           # Options: gemini | ollama
LLM_MODEL=gemini-1.5-flash    # Lightweight & fast Gemini model

# --- Embedding Model (CPU-friendly) ---
# Option 1: Smaller & faster (recommended for 8GB RAM)
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Option 2: Slightly better quality, still lightweight
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Backend Server ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# --- File Storage ---
UPLOAD_DIR=uploads
DATA_DIR=data
LOGS_DIR=logs

# --- Security ---
MAX_FILE_SIZE_MB=50           # Max PDF size in megabytes
ALLOWED_EXTENSIONS=.pdf       # Only allow PDF files

# --- RAG Configuration ---
CHUNK_SIZE=700                # Characters per chunk
CHUNK_OVERLAP=100             # Overlap between chunks
TOP_K_RESULTS=5               # Number of chunks to retrieve

# --- Performance ---
MAX_WORKERS=1                 # Keep at 1 for low-RAM systems
DEVICE=cpu                    # Force CPU inference
